# secrets.nix — agenix recipient list. Copy to `secrets.nix` and fill in the
# keys. This file controls who can decrypt each .age secret in this directory.
# Add the host key AFTER first boot, then re-key (`agenix -e <file>`) and commit.
let
  me   = "ssh-ed25519 AAAA...your-personal-key...";
  host = "ssh-ed25519 AAAA...server-host-key-after-first-boot...";
in {
  "tailscale-authkey.age".publicKeys = [ me host ];
  # Phase 2 OAuth secrets get added here as you create them, e.g.:
  # "oauth-client-secret.age".publicKeys = [ me host ];
}
